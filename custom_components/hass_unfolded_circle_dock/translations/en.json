    "button": {
      "identify": {
        "name": "Identify"
      },
      "stop_ir": {
        "name": "Stop IR"
      },
      "refresh": {
        "name": "Refresh sysinfo"
      },
      "reboot": {
        "name": "Reboot"
      }
    },
    "switch": {
      "serial_tcp": {
        "name": "Serial TCP"
      },
      "ir_learning_switch": {
        "name": "IR learning"
      },
