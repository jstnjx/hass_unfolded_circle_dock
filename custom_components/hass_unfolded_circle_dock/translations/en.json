{
  "config": {
    "flow_title": "{name}",
    "step": {
      "user": {
        "title": "Add your Unfolded Circle Dock",
        "description": "Enter your dock's IP address or hostname and its token. The model (Dock 3 or Dock Two) is detected automatically. The default token is 0000 unless you set a custom one. Leave port and path blank unless you have a non-standard setup.",
        "data": {
          "host": "Host or IP address",
          "port": "Port (advanced, leave blank to auto-detect)",
          "ws_path": "WebSocket path (advanced, leave blank to auto-detect)",
          "token": "Token / password",
          "use_tls": "Use TLS (wss://)",
          "name": "Name (optional)"
        }
      },
      "discovery_confirm": {
        "title": "Add {name}",
        "description": "Home Assistant found this Unfolded Circle dock on your network. Enter its token to add it (the default is 0000 unless you set a custom one).",
        "data": {
          "token": "Token / password",
          "name": "Name (optional)"
        }
      },
      "reconfigure": {
        "title": "Reconfigure dock",
        "description": "Update the connection details for this dock.",
        "data": {
          "host": "Host or IP address",
          "port": "Port",
          "ws_path": "WebSocket path",
          "token": "Token / password",
          "use_tls": "Use TLS (wss://)",
          "name": "Name (optional)"
        }
      }
    },
    "error": {
      "cannot_connect": "Failed to connect. Check the host, and that the dock is on the network.",
      "invalid_auth": "Authentication failed. Check the token/password.",
      "unknown": "An unexpected error occurred."
    },
    "abort": {
      "already_configured": "This dock is already configured.",
      "cannot_connect": "Couldn't reach the discovered dock.",
      "reconfigure_successful": "Dock reconfigured successfully."
    }
  },
