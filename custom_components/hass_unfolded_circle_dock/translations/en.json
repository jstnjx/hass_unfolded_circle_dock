        "name": "Status LED brightness"
      },
      "eth_led_brightness": {
        "name": "Ethernet LED brightness"
      }
    }
  },
  "services": {
    "send_ir": {
      "name": "Send IR",
      "description": "Send an infrared code from the dock.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        },
        "code": {
          "name": "Code",
          "description": "The IR code to transmit."
        },
        "format": {
          "name": "Format",
          "description": "The IR code format, e.g. pronto."
        },
        "repeat": {
          "name": "Repeat",
          "description": "Number of times to repeat the code."
        },
        "hold": {
          "name": "Hold",
          "description": "Hold the signal for this many milliseconds."
        },
        "int_side": {
          "name": "Internal side blaster",
          "description": "Emit from the internal side blaster."
        },
        "int_top": {
          "name": "Internal top blaster",
          "description": "Emit from the internal top blaster."
        },
        "ext1": {
          "name": "External port 1",
          "description": "Emit from external port 1."
        },
        "ext2": {
          "name": "External port 2",
          "description": "Emit from external port 2."
        }
      }
    },
    "stop_ir": {
      "name": "Stop IR",
      "description": "Stop an ongoing or repeating IR transmission.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        }
      }
    },
    "identify": {
      "name": "Identify",
      "description": "Flash the dock LEDs to physically locate it.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        }
      }
    },
    "set_volume": {
      "name": "Set volume",
      "description": "Set the dock volume (0-100).",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        },
        "volume": {
          "name": "Volume",
          "description": "Volume level from 0 to 100."
        }
      }
    },
    "set_brightness": {
      "name": "Set brightness",
      "description": "Set the brightness of the status and/or ethernet LEDs.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        },
        "status_led": {
          "name": "Status LED",
          "description": "Status LED brightness."
        },
        "eth_led": {
          "name": "Ethernet LED",
          "description": "Ethernet LED brightness."
        }
      }
    },
    "send_serial": {
      "name": "Send serial",
      "description": "Send data to an external port in RS232 mode.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        },
        "port": {
          "name": "Port",
          "description": "External port number."
        },
        "data": {
          "name": "Data",
          "description": "The data to send."
        }
      }
    },
    "set_port_mode": {
      "name": "Set port mode",
      "description": "Change the mode of an external port.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        },
        "port": {
          "name": "Port",
          "description": "External port number."
        },
        "mode": {
          "name": "Mode",
          "description": "The new mode, e.g. RS232 or TRIGGER_5V."
        },
        "baud_rate": {
          "name": "Baud rate",
          "description": "RS232 only. Line speed in bits/s. Defaults to 115200."
        },
        "data_bits": {
          "name": "Data bits",
          "description": "RS232 only. Defaults to 8."
        },
        "parity": {
          "name": "Parity",
          "description": "RS232 only. Defaults to none."
        },
        "stop_bits": {
          "name": "Stop bits",
          "description": "RS232 only. Defaults to 1."
        }
      }
    },
    "enable_serial_events": {
      "name": "Enable serial events",
      "description": "Subscribe or unsubscribe to incoming serial data events.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        },
        "port": {
          "name": "Port",
          "description": "External port number."
        },
        "enable": {
          "name": "Enable",
          "description": "Enable or disable serial events."
        }
      }
    },
    "refresh": {
      "name": "Refresh",
      "description": "Force an immediate refresh of dock system information.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        }
      }
    },
    "set_port_trigger": {
      "name": "Set 5V trigger",
      "description": "Assert, release, or pulse the 5V trigger output of an external port (port must be in TRIGGER_5V mode).",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        },
        "port": {
          "name": "Port",
          "description": "External port number."
        },
        "trigger": {
          "name": "State",
          "description": "Turn the trigger on or off."
        },
        "duration": {
          "name": "Pulse duration",
          "description": "Optional auto-release time in milliseconds."
        }
      }
    },
    "reboot": {
      "name": "Reboot",
      "description": "Reboot the dock.",
      "fields": {
        "device_id": {
          "name": "Dock",
          "description": "Target dock device."
        }
      }
    }
  }
}
